{
  "family": "safe-mind-finalizer",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/safe-mind-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/safe-mind-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "safe-mind-finalizer",
      "image": "<account-id>.dkr.ecr.<region>.amazonaws.com/safe-mind-api:<image-tag>",
      "essential": true,
      "command": ["python", "scripts/finalize_previous_day.py", "--send-alerts"],
      "environment": [
        { "name": "SAFE_MIND_ENV", "value": "production" },
        { "name": "SAFE_MIND_SIGNAL_STORE_PROVIDER", "value": "mongodb" },
        { "name": "SAFE_MIND_MONGODB_DATABASE", "value": "safe_mind" },
        { "name": "SAFE_MIND_PSYCHOLOGICAL_ANALYZER_PROVIDER", "value": "openai" },
        { "name": "SAFE_MIND_OPENAI_PSYCHOLOGICAL_ANALYZER_MODEL", "value": "gpt-4o-mini" },
        { "name": "SAFE_MIND_ENABLE_EMBEDDINGS", "value": "false" },
        { "name": "SAFE_MIND_PERSIST_SIGNALS", "value": "true" },
        { "name": "SAFE_MIND_EVAL_AUTH_USERNAME", "value": "safemind" }
      ],
      "secrets": [
        { "name": "SAFE_MIND_MONGODB_URI", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:safe-mind/prod/mongodb-uri" },
        { "name": "OPENAI_API_KEY", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:safe-mind/prod/openai-api-key" },
        { "name": "SAFE_MIND_EVAL_AUTH_PASSWORD", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:safe-mind/prod/eval-auth-password" },
        { "name": "SAFE_MIND_INTEGRATION_API_TOKEN", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:safe-mind/prod/integration-api-token" },
        { "name": "SAFE_MIND_PARENT_CONTACT_URL_TEMPLATE", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:safe-mind/prod/parent-contact-url-template" },
        { "name": "SAFE_MIND_PARENT_CONTACT_TOKEN", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:safe-mind/prod/parent-contact-token" },
        { "name": "SAFE_MIND_WHATSAPP_ACCESS_TOKEN", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:safe-mind/prod/whatsapp-access-token" },
        { "name": "SAFE_MIND_WHATSAPP_PHONE_NUMBER_ID", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:safe-mind/prod/whatsapp-phone-number-id" },
        { "name": "SAFE_MIND_WHATSAPP_TEMPLATE_NAME", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:safe-mind/prod/whatsapp-template-name" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/safe-mind-finalizer",
          "awslogs-region": "<region>",
          "awslogs-stream-prefix": "finalizer"
        }
      }
    }
  ]
}
