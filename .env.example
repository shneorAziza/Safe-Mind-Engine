SAFE_MIND_SIGNAL_DB_PATH=data/safe_mind_signals.sqlite3
SAFE_MIND_VECTOR_DB_PATH=data/safe_mind_vectors.sqlite3
SAFE_MIND_MONGODB_URI=
SAFE_MIND_MONGODB_DATABASE=safe_mind
SAFE_MIND_PERSIST_SIGNALS=true
SAFE_MIND_EVAL_AUTH_USERNAME=safemind
SAFE_MIND_EVAL_AUTH_PASSWORD=
SAFE_MIND_INTEGRATION_API_TOKEN=
SAFE_MIND_NEXT_ALERT_CALLBACK_URL=
SAFE_MIND_NEXT_ALERT_CALLBACK_TOKEN=
OPENAI_API_KEY=
